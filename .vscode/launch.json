{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONASYNCIODEBUG": "1",
                "DEBUG": "1",
                "PYTHONPATH": "src"
            }
        },
        
        {
            "name": "crosschat: server1",
            "type": "debugpy",
            "request": "launch",
            "module": "crosschat.main",
            "console": "integratedTerminal",
            "args": ["--config", "config.json"],
            "env": {
                "PYTHONASYNCIODEBUG": "1",
                "DEBUG": "1",
                "PYTHONPATH": "src"
            }
        },
        {
            "name": "crosschat: server2",
            "type": "debugpy",
            "request": "launch",
            "module": "crosschat.main",
            "console": "integratedTerminal",
            "args": ["--config", "config.metatest2.json"],
            "env": {
                "PYTHONASYNCIODEBUG": "1",
                "DEBUG": "1",
                "PYTHONPATH": "src"
            }
        }
    ]
}